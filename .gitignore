# Terraform local working dir
**/.terraform/*
**/.terraform-generated/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform crash logs
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json
